RewriteEngine On

# Página inicial
RewriteRule ^$ frontend/index.html [L]

# Se o arquivo ou pasta existir na raiz, não reescreve
RewriteCond %{REQUEST_FILENAME} -f [OR]
RewriteCond %{REQUEST_FILENAME} -d
RewriteRule ^ - [L]

# Permite acessar arquivos reais dentro de /frontend
RewriteCond %{DOCUMENT_ROOT}/frontend/$1 -f [OR]
RewriteCond %{DOCUMENT_ROOT}/frontend/$1 -d
RewriteRule ^(.*)$ frontend/$1 [L]

# Bloqueia acesso ao backend
RewriteRule ^backend/ - [F,L]